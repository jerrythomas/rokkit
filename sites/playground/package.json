		"test:e2e:update": "playwright test --update-snapshots"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.0.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@unocss/extractor-svelte": "^66.6.0",
		"@unocss/reset": "^66.6.0",
		"shiki": "^3.22.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.9.2",
		"unocss": "^66.6.0",
		"vite": "^7.1.6"
	},
	"dependencies": {
		"@rokkit/core": "workspace:*",
		"@rokkit/forms": "workspace:*",
		"@rokkit/icons": "workspace:*",
		"@rokkit/ui": "workspace:*",
		"@rokkit/themes": "workspace:*"
