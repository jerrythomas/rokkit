{
  "name": "@rokkit/app",
  "version": "1.2.0",
  "description": "App-level controls for Rokkit applications - theme management and UI chrome",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "svelte": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/types/index.ts"
    }
  },
  "files": [
    "src",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run build",
    "postpublish": "rm -f LICENSE",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "svelte-package -i src -o dist"
  },
  "dependencies": {
    "@rokkit/actions": "workspace:*",
    "@rokkit/core": "workspace:*",
    "@rokkit/states": "workspace:*",
    "@rokkit/ui": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^4.0.18",
    "playwright": "^1.58.2",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
