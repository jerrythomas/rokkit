    <div
      class="m-auto p-4 text-center text-gray-500"
      data-tree-empty=""
    >
      No data available
    </div>
    
    <!---->
     
    <div
      data-tree-list=""
      role="group"
    >
      
    </div>
    <!---->
     
    <!---->
  </div>
  
</div>
`;

