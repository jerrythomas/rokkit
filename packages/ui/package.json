{
  "name": "@rokkit/ui",
  "version": "1.3.0",
  "description": "Data driven UI components for Rokkit applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "svelte": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/types/index.ts"
    },
    "./utils/palette": {
      "types": "./dist/utils/palette.d.ts",
      "default": "./src/utils/palette.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run build",
    "postpublish": "rm -f LICENSE",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build": "svelte-package -i src -o dist"
  },
  "keywords": [
    "ui",
    "components",
    "svelte",
    "menu",
    "dropdown"
  ],
  "dependencies": {
    "@rokkit/core": "workspace:*",
    "@rokkit/data": "workspace:*",
    "@rokkit/states": "workspace:*",
    "@rokkit/actions": "workspace:*",
    "marked": "^15.0.0",
    "dompurify": "^3.0.0"
  },
  "peerDependencies": {
    "shiki": "^3.23.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.3",
    "typescript": "^5.9.3"
  }
}
