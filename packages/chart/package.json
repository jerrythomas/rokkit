{
  "name": "@rokkit/chart",
  "version": "1.2.0",
  "type": "module",
  "description": "Data-driven chart components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "npm": {
    "publish": false
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run clean && bun run build",
    "postpublish": "rm -f LICENSE",
    "clean": "rm -rf dist",
    "build": "svelte-package -i src -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.svelte",
    "dist/**/*.d.ts",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    },
    "./patterns": "./src/patterns/index.js",
    "./symbols": "./src/symbols/index.js",
    "./symbols/*": "./src/symbols/*",
    "./patterns/*": "./src/patterns/*",
    "./charts/*": "./src/charts/*"
  },
  "dependencies": {
    "@rokkit/core": "workspace:latest",
    "@rokkit/data": "workspace:latest",
    "@rokkit/states": "workspace:latest",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-format": "^3.1.2",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-transition": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "ramda": "^0.32.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-format": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/ramda": "^0.31.1",
    "svelte-check": "^4.4.3"
  }
}
