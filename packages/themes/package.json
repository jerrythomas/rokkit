{
  "name": "@rokkit/themes",
  "version": "1.3.2",
  "description": "Theme styles for @rokkit/ui components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./styles": { "style": "./dist/index.css", "default": "./dist/index.css" },
    "./base.css": { "style": "./dist/base.css", "default": "./dist/base.css" },
    "./rokkit.css": { "style": "./dist/rokkit.css", "default": "./dist/rokkit.css" },
    "./minimal.css": { "style": "./dist/minimal.css", "default": "./dist/minimal.css" },
    "./material.css": { "style": "./dist/material.css", "default": "./dist/material.css" },
    "./frosted.css": { "style": "./dist/frosted.css", "default": "./dist/frosted.css" },
    "./zen-sumi.css": { "style": "./dist/zen-sumi.css", "default": "./dist/zen-sumi.css" },
    "./base": { "style": "./dist/base.css", "default": "./dist/base.css" },
    "./base/*": { "style": "./dist/base/*.css", "default": "./dist/base/*.css" },
    "./rokkit": { "style": "./dist/rokkit.css", "default": "./dist/rokkit.css" },
    "./rokkit/*": { "style": "./dist/rokkit/*.css", "default": "./dist/rokkit/*.css" },
    "./minimal": { "style": "./dist/minimal.css", "default": "./dist/minimal.css" },
    "./minimal/*": { "style": "./dist/minimal/*.css", "default": "./dist/minimal/*.css" },
    "./material": { "style": "./dist/material.css", "default": "./dist/material.css" },
    "./material/*": { "style": "./dist/material/*.css", "default": "./dist/material/*.css" },
    "./frosted": { "style": "./dist/frosted.css", "default": "./dist/frosted.css" },
    "./frosted/*": { "style": "./dist/frosted/*.css", "default": "./dist/frosted/*.css" },
    "./zen-sumi": { "style": "./dist/zen-sumi.css", "default": "./dist/zen-sumi.css" },
    "./zen-sumi/*": { "style": "./dist/zen-sumi/*.css", "default": "./dist/zen-sumi/*.css" }
  },
  "files": [
    "src",
    "dist",
    "build.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "bun run build.mjs",
    "prepublishOnly": "bun run build.mjs && cp ../../LICENSE .",
    "postpublish": "rm -f LICENSE",
    "build": "bun run build.mjs"
  },
  "dependencies": {
    "@rokkit/core": "workspace:*"
  },
  "devDependencies": {
    "@rokkit/unocss": "workspace:*",
    "magic-string": "^0.30.21",
    "unocss": "^66.5.1"
  },
  "keywords": [
    "themes",
    "css",
    "styles",
    "ui"
  ]
}
