{
  "name": "@rokkit/themes",
  "version": "1.0.0-next.147",
  "description": "Theme styles for @rokkit/ui components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "style": "./src/index.css",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./styles": "./src/index.css",
    "./dist": "./dist/index.css",
    "./dist/base": "./dist/base.css",
    "./dist/rokkit": "./dist/rokkit.css",
    "./dist/minimal": "./dist/minimal.css",
    "./dist/material": "./dist/material.css",
    "./dist/glass": "./dist/glass.css",
    "./dist/grada-ui": "./dist/grada-ui.css",
    "./base.css": "./dist/base.css",
    "./rokkit.css": "./dist/rokkit.css",
    "./minimal.css": "./dist/minimal.css",
    "./material.css": "./dist/material.css",
    "./glass.css": "./dist/glass.css",
    "./grada-ui.css": "./dist/grada-ui.css",
    "./base": "./src/base/index.css",
    "./base/*": "./src/base/*.css",
    "./rokkit": "./src/rokkit/index.css",
    "./rokkit/*": "./src/rokkit/*.css",
    "./minimal": "./src/minimal/index.css",
    "./minimal/*": "./src/minimal/*.css",
    "./material": "./src/material/index.css",
    "./material/*": "./src/material/*.css",
    "./glass": "./src/glass/index.css",
    "./glass/*": "./src/glass/*.css",
    "./grada-ui": "./src/grada-ui/index.css",
    "./grada-ui/*": "./src/grada-ui/*.css"
  },
  "files": [
    "src",
    "dist",
    "build.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run build.mjs",
    "postpublish": "rm -f LICENSE",
    "build": "bun run build.mjs"
  },
  "dependencies": {
    "@rokkit/core": "workspace:*"
  },
  "devDependencies": {
    "magic-string": "^0.30.21",
    "unocss": "^66.5.1"
  },
  "keywords": [
    "themes",
    "css",
    "styles",
    "ui"
  ]
}
