{
  "name": "@rokkit/themes",
  "version": "1.0.0-next.162",
  "description": "Theme styles for @rokkit/ui components",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "style": "./src/index.css",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./styles": { "style": "./src/index.css", "default": "./src/index.css" },
    "./dist": { "style": "./dist/index.css", "default": "./dist/index.css" },
    "./dist/base": { "style": "./dist/base.css", "default": "./dist/base.css" },
    "./dist/rokkit": { "style": "./dist/rokkit.css", "default": "./dist/rokkit.css" },
    "./dist/minimal": { "style": "./dist/minimal.css", "default": "./dist/minimal.css" },
    "./dist/material": { "style": "./dist/material.css", "default": "./dist/material.css" },
    "./dist/frosted": { "style": "./dist/frosted.css", "default": "./dist/frosted.css" },
    "./dist/grada-ui": { "style": "./dist/grada-ui.css", "default": "./dist/grada-ui.css" },
    "./dist/daisy-ui": { "style": "./dist/daisy-ui.css", "default": "./dist/daisy-ui.css" },
    "./dist/shadcn": { "style": "./dist/shadcn.css", "default": "./dist/shadcn.css" },
    "./dist/bits-ui": { "style": "./dist/bits-ui.css", "default": "./dist/bits-ui.css" },
    "./dist/carbon": { "style": "./dist/carbon.css", "default": "./dist/carbon.css" },
    "./dist/ant-design": { "style": "./dist/ant-design.css", "default": "./dist/ant-design.css" },
    "./base.css": { "style": "./dist/base.css", "default": "./dist/base.css" },
    "./rokkit.css": { "style": "./dist/rokkit.css", "default": "./dist/rokkit.css" },
    "./minimal.css": { "style": "./dist/minimal.css", "default": "./dist/minimal.css" },
    "./material.css": { "style": "./dist/material.css", "default": "./dist/material.css" },
    "./frosted.css": { "style": "./dist/frosted.css", "default": "./dist/frosted.css" },
    "./grada-ui.css": { "style": "./dist/grada-ui.css", "default": "./dist/grada-ui.css" },
    "./daisy-ui.css": { "style": "./dist/daisy-ui.css", "default": "./dist/daisy-ui.css" },
    "./shadcn.css": { "style": "./dist/shadcn.css", "default": "./dist/shadcn.css" },
    "./bits-ui.css": { "style": "./dist/bits-ui.css", "default": "./dist/bits-ui.css" },
    "./carbon.css": { "style": "./dist/carbon.css", "default": "./dist/carbon.css" },
    "./ant-design.css": { "style": "./dist/ant-design.css", "default": "./dist/ant-design.css" },
    "./base": { "style": "./src/base/index.css", "default": "./src/base/index.css" },
    "./base/*": { "style": "./src/base/*.css", "default": "./src/base/*.css" },
    "./rokkit": { "style": "./src/rokkit/index.css", "default": "./src/rokkit/index.css" },
    "./rokkit/*": { "style": "./src/rokkit/*.css", "default": "./src/rokkit/*.css" },
    "./minimal": { "style": "./src/minimal/index.css", "default": "./src/minimal/index.css" },
    "./minimal/*": { "style": "./src/minimal/*.css", "default": "./src/minimal/*.css" },
    "./material": { "style": "./src/material/index.css", "default": "./src/material/index.css" },
    "./material/*": { "style": "./src/material/*.css", "default": "./src/material/*.css" },
    "./frosted": { "style": "./src/frosted/index.css", "default": "./src/frosted/index.css" },
    "./frosted/*": { "style": "./src/frosted/*.css", "default": "./src/frosted/*.css" },
    "./grada-ui": { "style": "./src/grada-ui/index.css", "default": "./src/grada-ui/index.css" },
    "./grada-ui/*": { "style": "./src/grada-ui/*.css", "default": "./src/grada-ui/*.css" },
    "./daisy-ui": { "style": "./src/daisy-ui/index.css", "default": "./src/daisy-ui/index.css" },
    "./daisy-ui/*": { "style": "./src/daisy-ui/*.css", "default": "./src/daisy-ui/*.css" },
    "./shadcn": { "style": "./src/shadcn/index.css", "default": "./src/shadcn/index.css" },
    "./shadcn/*": { "style": "./src/shadcn/*.css", "default": "./src/shadcn/*.css" },
    "./bits-ui": { "style": "./src/bits-ui/index.css", "default": "./src/bits-ui/index.css" },
    "./bits-ui/*": { "style": "./src/bits-ui/*.css", "default": "./src/bits-ui/*.css" },
    "./carbon": { "style": "./src/carbon/index.css", "default": "./src/carbon/index.css" },
    "./carbon/*": { "style": "./src/carbon/*.css", "default": "./src/carbon/*.css" },
    "./ant-design": { "style": "./src/ant-design/index.css", "default": "./src/ant-design/index.css" },
    "./ant-design/*": { "style": "./src/ant-design/*.css", "default": "./src/ant-design/*.css" }
  },
  "files": [
    "src",
    "dist",
    "*.css",
    "build.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run build.mjs",
    "postpublish": "rm -f LICENSE",
    "build": "bun run build.mjs"
  },
  "dependencies": {
    "@rokkit/core": "workspace:*"
  },
  "devDependencies": {
    "magic-string": "^0.30.21",
    "unocss": "^66.5.1"
  },
  "keywords": [
    "themes",
    "css",
    "styles",
    "ui"
  ]
}
