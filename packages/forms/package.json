{
  "name": "@rokkit/forms",
  "version": "1.3.2",
  "description": "Form building components for Rokkit applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "module": "src/index.js",
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun run clean && bun run build",
    "postpublish": "rm -f LICENSE",
    "clean": "rm -rf dist",
    "build": "svelte-package -i src -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.svelte",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./src": "./src",
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "import": "./src/lib/index.js"
    }
  },
  "dependencies": {
    "@rokkit/core": "workspace:latest",
    "@rokkit/data": "workspace:latest",
    "@rokkit/states": "workspace:latest",
    "@rokkit/ui": "workspace:latest",
    "ramda": "^0.32.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/ramda": "^0.31.1",
    "svelte-check": "^4.4.3"
  }
}
