{
  "name": "@rokkit/forms",
  "version": "1.0.0-next.122",
  "module": "src/index.js",
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "build": "bun clean && bun prepublishOnly"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.svelte",
    "dist/**/*.d.ts"
  ],
  "exports": {
    "./src": "./src",
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    }
  },
  "dependencies": {
    "@rokkit/core": "workspace:latest",
    "@rokkit/states": "workspace:latest",
    "@rokkit/ui": "workspace:latest",
    "@rokkit/bits-ui": "workspace:latest",
    "ramda": "^0.30.1",
    "valibot": "^1.1.0"
  }
}
