{
  "name": "@rokkit/forms",
  "version": "1.0.0-next.157",
  "description": "Form building components for Rokkit applications",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "module": "src/index.js",
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && tsc --project tsconfig.build.json",
    "postpublish": "rm -f LICENSE",
    "clean": "rm -rf dist",
    "build": "bun clean && bun prepublishOnly"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.svelte",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./src": "./src",
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js",
      "svelte": "./src/index.js"
    },
    "./lib": {
      "import": "./src/lib/index.js"
    }
  },
  "dependencies": {
    "@rokkit/core": "workspace:latest",
    "@rokkit/data": "workspace:latest",
    "@rokkit/states": "workspace:latest",
    "@rokkit/ui": "workspace:latest",
    "ramda": "^0.32.0"
  }
}
