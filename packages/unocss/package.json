{
  "name": "@rokkit/unocss",
  "version": "1.0.0-next.136",
  "description": "UnoCSS preset for Rokkit — one-line setup for colors, shortcuts, icons, and dark mode.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "license": "MIT",
  "type": "module",
  "publishConfig": { "access": "public" },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bunx tsc --project tsconfig.build.json",
    "postpublish": "rm -f LICENSE",
    "clean": "rm -rf dist",
    "build": "bun clean && bun prepublishOnly"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.css",
    "dist/**/*.d.ts",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js"
    },
    "./patterns.css": "./src/patterns.css"
  },
  "dependencies": {
    "@rokkit/core": "workspace:*",
    "@rokkit/icons": "workspace:*",
    "@unocss/extractor-svelte": "^66.6.1",
    "unocss": "^66.6.1"
  }
}
