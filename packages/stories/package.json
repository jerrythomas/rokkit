{
  "name": "@rokkit/stories",
  "version": "1.0.0-next.133",
  "description": "Utilities for building tutorials.",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "story",
    "tutorial",
    "markdown",
    "svelte",
    "svelte-kit"
  ],
  "author": "Jerry Thomas<me@jerrythomas.name>",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src/**/*.js",
    "dist/**/*.d.ts",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE . && bun clean && bun tsc --project tsconfig.build.json",
    "postpublish": "rm -f LICENSE",
    "clean": "rm -rf dist",
    "build": "bun prepublishOnly"
  },
  "dependencies": {
    "@vitest/expect": "^4.0.18",
    "frontmatter": "^0.0.3",
    "ramda": "^0.32.0",
    "shiki": "^3.23.0",
    "@rokkit/core": "workspace:latest"
  }
}
