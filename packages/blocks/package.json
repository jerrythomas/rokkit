      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "dependencies": {
    "dompurify": "^3.0.0"
  },
  "peerDependencies": {
    "@rokkit/chart": "workspace:*",
    "@rokkit/core": "workspace:*",
    "@rokkit/ui": "workspace:*",
    "mermaid": ">=11.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rokkit/chart": "workspace:*",
    "@rokkit/core": "workspace:*",
    "@rokkit/ui": "workspace:*"
  }
