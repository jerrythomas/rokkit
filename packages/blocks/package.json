{
  "name": "@rokkit/blocks",
  "version": "1.0.0-next.161",
  "description": "Markdown block plugins for Rokkit (Plot, Table, Sparkline, Mermaid)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE .",
    "postpublish": "rm -f LICENSE"
  },
