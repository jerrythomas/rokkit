{
  "name": "@rokkit/icons",
  "version": "1.0.1",
  "description": "A minimal icon set for use in Rokkit applications.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerrythomas/rokkit.git"
  },
  "author": "Jerry Thomas <me@jerrythomas.name>",
  "exports": {
    "./package.json": "./package.json",
    "./ui.json": "./lib/base.json",
    "./semantic.json": "./lib/semantic.json",
    "./twotone.json": "./lib/twotone.json",
    "./glyph.json": "./lib/glyph.json",
    "./components.json": "./lib/glyph.json",
    "./auth.json": "./lib/auth.json",
    "./app.json": "./lib/app.json",
    ".": "./lib/base.json",
    "./utils": "./src/convert.js"
  },
  "files": [
    "lib/**/*",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@iconify-json/solar": "^1.2.5",
    "@rokkit/cli": "workspace:latest",
    "simple-icons": "^16.11.0"
  },
  "scripts": {
    "prepublishOnly": "cp ../../LICENSE .",
    "postpublish": "rm -f LICENSE",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "build": "rokkit-cli build && bun format",
    "latest": "bun update --latest",
    "release": "bun publish --access public"
  },
  "type": "module"
}
