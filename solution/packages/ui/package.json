{
  "name": "@rokkit/ui",
  "version": "1.0.0-next.126",
  "description": "Data driven UI components for Rokkit applications",
  "type": "module",
  "svelte": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./utils/palette": {
      "types": "./src/utils/palette.ts",
      "default": "./src/utils/palette.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo 'No build step needed for source-only package'"
  },
  "keywords": [
    "ui",
    "components",
    "svelte",
    "menu",
    "dropdown"
  ],
  "dependencies": {
    "@rokkit/core": "workspace:*",
    "@rokkit/data": "workspace:*",
    "@rokkit/states": "workspace:*",
    "@rokkit/actions": "workspace:*"
  },
  "peerDependencies": {
    "shiki": "^3.23.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/browser": "^4.0.18",
    "playwright": "^1.58.2",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
