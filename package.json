{
  "name": "rokkit",
  "version": "1.0.0-next.156",
  "private": true,
  "prettier": "./config/.prettierrc",
  "module": "src/index.js",
  "type": "module",
  "scripts": {
    "clean": "find . -name  node_modules -o -name .svelte-kit -o -name dist | xargs rm -rf",
    "test:unit": "vitest",
    "test:ci": "vitest run",
    "test:ui": "vitest run --project ui",
    "test:e2e": "cd site && npx playwright test",
    "coverage": "vitest run --coverage",
    "format": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write .",
    "lint": "eslint --config config/eslint.config.mjs --fix",
    "bump": "bumpp --configFilePath config/bump.config.js",
    "bump:next": "bumpp --configFilePath config/bump.config.js --preid=next",
    "upgrade:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun update --latest' \\;",
    "publish:all": "for dir in ./packages/*/; do grep -q '\"private\": true' \"${dir}package.json\" 2>/dev/null || (cd \"$dir\" && bun publish); done",
    "build:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun run build' \\;",
    "release": "bun run clean && bun install && bun run publish:all"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.22",
    "@types/dompurify": "^3.2.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "bumpp": "^10.2.3",
    "eslint": "^9.35.0",
    "eslint-plugin-svelte": "^3.12.3",
    "globals": "^17.3.0",
    "jsdom": "^27.0.0",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.0.1",
    "svelte": "^5.53.3",
    "svelte-eslint-parser": "^1.5.1",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "workspaces": [
    "./packages/*",
    "./site",
    "./demo"
  ],
  "dependencies": {
    "@types/ramda": "^0.31.1",
    "dompurify": "^3.3.3"
  },
  "overrides": {
    "svelte": "^5.53.3"
  }
}
