{
  "name": "rokkit",
  "version": "1.0.0-next.121",
  "module": "src/index.js",
  "type": "module",
  "npm": {
    "publish": false
  },
  "scripts": {
    "clean": "find . -name node_modules | xargs rm -rf && find . -name .svelte-kit | xargs rm -rf",
    "test:unit": "vitest",
    "test:ci": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "lockfile": "pnpm install --lockfile-only",
    "bump": "bun run lockfile && bumpp --no-push",
    "bump:next": "bun run lockfile && bumpp --preid=next --no-push",
    "publish:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun publish' \\;",
    "build:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun run build' \\;",
    "release": "bun run publish:all"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.17",
    "@vitest/coverage-v8": "^3.2.4",
    "bumpp": "^10.2.0",
    "eslint": "^9.30.1",
    "eslint-plugin-svelte": "^3.10.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "rimraf": "^6.0.1",
    "vite": "^7.0.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "./packages/*",
    "./sites/*"
  ],
  "dependencies": {
    "@types/ramda": "^0.30.2"
  }
}
