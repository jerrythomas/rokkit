{
  "name": "rokkit",
  "version": "1.0.0-next.125",
  "module": "src/index.js",
  "type": "module",
  "npm": {
    "publish": false
  },
  "scripts": {
    "clean": "find . -name  node_modules -o -name .svelte-kit -o -name dist | xargs rm -rf",
    "test:unit": "vitest",
    "test:ci": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "lockfile": "pnpm install --lockfile-only",
    "bump": "bun run lockfile && bumpp --no-push",
    "bump:next": "bun run lockfile && bumpp --preid=next --no-push",
    "upgrade:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun update --latest' \\;",
    "publish:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun publish' \\;",
    "build:all": "find ./packages -type d -depth 1 -exec sh -c 'cd \"{}\" && bun run build' \\;",
    "release": "bun run clean && bun install && bun run publish:all"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@testing-library/svelte": "^5.2.8",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.22",
    "@vitest/coverage-v8": "^3.2.4",
    "bumpp": "^10.2.3",
    "eslint": "^9.35.0",
    "eslint-plugin-svelte": "^3.12.3",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "workspaces": [
    "./packages/*",
    "./sites/*"
  ],
  "dependencies": {
    "@types/ramda": "^0.31.1"
  }
}
